DB_NAME=chembl_db
DB_USER=your_pg_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
PG_STATEMENT_TIMEOUT_MS=30000

# Milvus Lite — local embedded file (no server, no Docker).
# NOTE: do NOT name this MILVUS_URI — pymilvus reads that env var at import
# time and fails when the value is a file path instead of an HTTP URL.
MILVUS_DB_PATH=./data/milvus_lite.db
MILVUS_COLLECTION=chembl_morgan_2048
MILVUS_TOP_K=200
MILVUS_MIN_TANIMOTO=0.65
MILVUS_FINAL_TOP_K=100

OLLAMA_BASE_URL=http://localhost:11434
CHEMLLM_MODEL=chemllm:latest
CHEMLLM_TEMPERATURE=0.2

DEEPCHEM_CACHE_DIR=./data/deepchem_cache

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

EVIDENCE_CACHE_TTL_S=3600
